  {
    "id": "814e23bd46866b61",
    "type": "function",
    "z": "eae280a2e3d9d24a",
    "name": "Schedule + Moisture Logic",
    "func": "let moistureThresholds = {\n    ss1: 40, ss2: 40, ss3: 40, ss4: 40,\n    ss5: 40, ss6: 40, ss7: 40, ss8: 40\n};\n\nlet valveMap = {\n    ss1: { vnode: 'relay-node1', fport: 6 },\n    ss2: { vnode: 'relay-node1', fport: 7 },\n    ss3: { vnode: 'relay-node1', fport: 8 },\n    ss4: { vnode: 'relay-node1', fport: 9 },\n    ss5: { vnode: 'relay-node-2', fport: 6 },\n    ss6: { vnode: 'relay-node-2', fport: 7 },\n    ss7: { vnode: 'relay-node-2', fport: 8 },\n    ss8: { vnode: 'relay-node-2', fport: 9 }\n};\n\nlet now = new Date();\nlet dow = now.getDay(); // 0 = Sun\nlet scheduleType = msg.topic || 'scheduled';\nlet results = [];\n\nlet schedule = { \n     relay-node1 : [0, 2, 4], // Sun, Tue, Thu\n    relay-node-2 : [1, 3, 5]  // Mon, Wed, Fri\n};\n\nfor (let vnode in schedule) {\n   // if (scheduleType === 'scheduled' && !schedule[vnode].includes(dow)) continue;\n\n    for (let sensor in valveMap) {\n        let map = valveMap[sensor];\n        if (map.vnode !== vnode) continue;\n\n        let moisture = flow.get(sensor + \"_soil_pct\") || 0;\n        let temp = flow.get(vnode + \"_tempF\") || 80;\n        let threshold = moistureThresholds[sensor];\n        let hot = temp >= 100;\n\n        let shouldRun =\n            (scheduleType === 'scheduled' && moisture <= threshold) ||\n            (scheduleType === 'override-4pm' && hot && moisture <= threshold) ||\n            (scheduleType === 'override-6pm' && hot && moisture <= threshold);\n\n        if (shouldRun) {\n            let onMessage = {\n                topic: `v3/5571-258-irri@ttn/devices/${vnode}/down/push`,\n                payload: {\n                    downlinks: [\n                        {\n                            frm_payload: Buffer.from([1]).toString('base64'),\n                            f_port: map.fport,\n                            priority: \"NORMAL\"\n                        }\n                    ]\n                },\n                qos: 1,\n                retain: false\n            };\n\n            results.push(onMessage);\n\n            // Send to OFF handler with just node and port\n            results.push({ vnode: vnode, fport: map.fport });\n        }\n\n     \n    }\n\n    }\nreturn results;\n",
    "outputs": 1,
    "timeout": 0,
    "noerr": 15,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 580,
    "y": 220,
    "wires": [
      [
        "mqtt_out",
        "e54a5c2d8a72685b",
        "95cb1dbc6ff77f96"
      ]
    ]
  },
