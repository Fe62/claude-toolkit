  {
    "id": "fn_set_soil",
    "type": "function",
    "z": "eae280a2e3d9d24a",
    "name": "Set Soil % (flow.set)",
    "func": "\nlet device = msg.payload.device_id;\nlet soil = msg.payload.soil_pct;\n\nif (device && typeof soil !== \"undefined\") {\n    flow.set(device + \"_soil_pct\", soil);\n}\n\nreturn null;\n",
    "outputs": 0,
    "timeout": "",
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 900,
    "y": 340,
    "wires": []
  },
  {
