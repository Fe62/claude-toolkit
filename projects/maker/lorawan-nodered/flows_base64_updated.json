  {
    "id": "95cb1dbc6ff77f96",
    "type": "function",
    "z": "eae280a2e3d9d24a",
    "name": "Schedule OFF",
    "func": "let delayMs = 300000; // 5 minutes = 300,000 ms\n// let delayMs = 15000; // 15 seconds\n\nlet vnode = msg.vnode;\nlet fport = msg.fport;\n\n// Build the OFF message with payload [0] \u2192 base64: \"AA==\"\nlet offMessage = {\n    topic: `v3/5571-258-irri@ttn/devices/${vnode}/down/push`,\n    payload: {\n        downlinks: [\n            {\n                frm_payload: Buffer.from([0]).toString('base64'),\n                f_port: fport,\n                priority: \"NORMAL\"\n            }\n        ]\n    },\n    qos: 1,\n    retain: false\n};\n\n// Use setTimeout to delay the send\nsetTimeout(() => {\n    node.send(offMessage);\n}, delayMs);\n\n// This function itself doesn't return anything immediately\nreturn null;\n",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 560,
    "y": 280,
    "wires": [
      [
        "mqtt_out"
      ]
    ]
  },
